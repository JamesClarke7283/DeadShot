{
  "name": "deadshot",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "run-browser": "deno run -A src/server/server.ts",
    "run-client": "deno run -A --unstable-ffi src/server/desktop.ts",
    "fetch-assets": "deno run -A src/tools/fetch_assets.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "test": "deno test -A",
    "check": "deno check src/main.ts src/server/server.ts"
  },
  "imports": {
    "three": "npm:three@0.180.0",
    "three/addons/": "npm:three@0.180.0/examples/jsm/",
    "esbuild": "npm:esbuild@0.24.2",
    "@luca/esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@0.11.1",
    "@webview/webview": "jsr:@webview/webview@0.9.0",
    "@std/path": "jsr:@std/path@1.0.8",
    "@std/media-types": "jsr:@std/media-types@1.1.0",
    "@std/assert": "jsr:@std/assert@1.0.10",
    "@std/fs": "jsr:@std/fs@1.0.8"
  },
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable", "deno.ns"],
    "strict": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": ["public/", "docs/"]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "exclude": ["public/vendor/", "docs/"]
  },
  "exclude": [
    "public/models",
    "public/audio/cache",
    ".loop*"
  ]
}
